{
  "expo": {
    "name": "project-movie-anime",
    "slug": "project-movie-anime",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logoapp.png",
    "scheme": "projectmovieanime",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF8F0",
        "foregroundImage": "./assets/images/logoapp.png",
        "monochromeImage": "./assets/images/logoapp.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logoapp.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logoapp.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFF8F0",
          "dark": {
            "backgroundColor": "#2C1810"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
